# frontend/.env.example
# Copy to frontend/.env.local and adjust as needed.
# NEXT_PUBLIC_ vars are exposed to the browser.

# Base URL of the backend API.
# Local dev:         http://localhost:5000
# Docker Compose:    http://localhost:5000  (the browser still talks to host ports)
# Production on EC2: http://<EC2-PUBLIC-IP>:5000
NEXT_PUBLIC_API_URL=http://localhost:5000
