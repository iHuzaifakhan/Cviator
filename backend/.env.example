# backend/.env.example
# Copy this file to backend/.env and edit as needed.
# Never commit the real .env — it's in .gitignore.

# Port the Express API listens on
PORT=5000

# MongoDB connection string. Used only when USE_DB=true.
# Local:   mongodb://localhost:27017/cviator
# Docker:  mongodb://mongo:27017/cviator
# Atlas:   mongodb+srv://<user>:<pwd>@cluster.mongodb.net/cviator
MONGO_URI=mongodb://localhost:27017/cviator

# Set to "true" to enable resume persistence via MongoDB.
# Leave "false" to run completely DB-less (PDF generation still works).
USE_DB=false
